                },
                "examples": {
                  "success": {
                    "summary": "登录成功",
                    "value": {
                      "code": 1,
                      "userInfo": {
                        "id": 1,
                        "userid": 10000000,
                        "deviceid": "UUID_DEVICE_001",
                        "clientCode": "PVMB8x1N",
                        "platForm": 0,
                        "nation": "CN",
                        "localLanguage": "zh-CN",
                        "brand": "Apple",
                        "nickName": "HappyUser123",
                        "email": "0",
