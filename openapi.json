                "type": "object",
                "required": [
                  "clientid",
                  "deviceid",
                  "pass"
                ],
                "title": "JoinSchemas",
                "description": "Join 请求文档模型。",
                "examples": [
                  {
                    "brand": "Apple",
                    "clientid": "PVMB8x1N",
                    "deviceid": "UUID_DEVICE_001",
                    "localLanguage": "zh-CN",
                    "nation": "CN",
                    "pass": "771f83e",
                    "platform": "0"
                  },
                  {
                    "clientid": "PVMB8x1N",
                    "deviceid": "UUID_DEVICE_001",
                    "pass": "90bc1bd"
                  }
                ]
              }
            }
          },
          "required": true
