        "operationId": "join_api_v1_join__post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "clientid": {
                    "type": "string",
                    "title": "Clientid",
                    "description": "客户端ID"
                  },
                  "deviceid": {
                    "type": "string",
                    "title": "Deviceid",
                    "description": "设备ID"
                  },
                  "platform": {
                    "anyOf": [
                      {
                        "type": "string"
                      },
                      {
                        "type": "null"
                      }
                    ],
                    "title": "Platform",
                    "description": "平台: 0=ios, 1=android"
                  },
                  "nation": {
                    "anyOf": [
                      {
                        "type": "string"
                      },
                      {
                        "type": "null"
                      }
                    ],
                    "title": "Nation",
                    "description": "国家代码"
                  },
                  "localLanguage": {
                    "anyOf": [
                      {
                        "type": "string"
                      },
                      {
                        "type": "null"
                      }
